<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">


<suite name="Open cart Regression Suite" verbose="3" parallel="tests"
       thread-count="3"  >

    <listeners>
        <listener class-name="com.qa.opencart.listeners.ExtentReportListener" />
