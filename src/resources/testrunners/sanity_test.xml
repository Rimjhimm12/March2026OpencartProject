<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">


<suite name="Open cart Regression Suite" verbose="3" parallel="tests"
       thread-count="3"  >


    <test name="Login Page Test ">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.qa.opencart.tests.LoginPageTest" />
        </classes>
    </test>

    <test name="Account Page Test ">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.qa.opencart.tests.AccountPageTest" />
        </classes>
    </test>

    <test name="Search Result Page Test ">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.qa.opencart.tests.SearchResultPageTest" />
        </classes>
    </test>

    <test name="Product Info Page Test ">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.qa.opencart.tests.ProductInfoPageTest" />
        </classes>
    </test>

    <test name="Shopping Cart Page Test ">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.qa.opencart.tests.ShoppingCartPageTest" />
        </classes>
    </test>

    <test name="Registration Page Test ">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.qa.opencart.tests.RegistrationPageTest" />
        </classes>
    </test>


</suite>